def test_make_cache_key_uses_version_and_node_ids_only():
    assert make_cache_key("v1", "opts", "a", "b") == "v1|opts|a|b"
    assert make_cache_key("v1", "opts", "a", "b") == make_cache_key("v1", "opts", "a", "b")


def test_first_put_increases_size():
    cache = RouteCache(limit=1000)
    cache.put(
        "v1",
        "opts",
        "node-start",
        "node-end",
        CachedGraphPath(node_ids=["node-start", "node-end"], graph_distance_meters=1.0),
    )
    assert cache.size == 1


def test_get_moves_entry_to_mru_for_lru_eviction():
    cache = RouteCache(limit=2)
    cache.put("v", "o", "a", "b", CachedGraphPath(["a", "b"], 1.0))
    cache.put("v", "o", "c", "d", CachedGraphPath(["c", "d"], 2.0))
    assert cache.get("v", "o", "a", "b") is not None
    cache.put("v", "o", "e", "f", CachedGraphPath(["e", "f"], 3.0))
    assert cache.get("v", "o", "c", "d") is None
    assert cache.get("v", "o", "a", "b") is not None
    assert cache.size == 2



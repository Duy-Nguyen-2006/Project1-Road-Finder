{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "cd frontend && npm install && VITE_API_BASE_URL= npm run build",
  "outputDirectory": "frontend/dist",
  "installCommand": "cd frontend && npm install",
  "framework": null,
  "rewrites": [
    { "source": "/auth/:path*", "destination": "/api" },
    { "source": "/health", "destination": "/api" },
    { "source": "/graph/:path*", "destination": "/api" },
    { "source": "/route", "destination": "/api" },
    { "source": "/assignments", "destination": "/api" },
    { "source": "/tours", "destination": "/api" },
    { "source": "/fleet", "destination": "/api" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/*.py": {
      "memory": 1024,
      "maxDuration": 60,
      "includeFiles": "backend/app/**"
    }
  }
}